import asyncio
import json
import logging
import os
import time
from collections import deque
from dataclasses import dataclass
from pathlib import Path
from threading import Event

import cv2
import mediapipe as mp
import numpy as np
from fastapi import FastAPI, WebSocket, WebSocketDisconnect

BASE_DIR = Path(__file__).resolve().parents[1]
MODEL_PATH = BASE_DIR / "ml" / "artifacts" / "gesture_model.joblib"
try:
    import joblib  # type: ignore
except Exception:  # pragma: no cover
    joblib = None
HOST = "0.0.0.0"
PORT = 8000
DEBUG_WINDOW = (os.getenv("GESTURE_DEBUG_WINDOW") or "").strip().lower() in ("1", "true", "yes", "on")

@dataclass
class Settings:
    count_stable_n: int = 3
    cooldown_sec: float = 1.0
    send_hz: float = 10.0
    camera_index: int = 0
    reconnect_sec: float = 2.0
    model_enabled: bool = True
    model_conf_thresh: float = 0.85
    model_stable_n: int = 7
    model_cooldown_sec: float = 0.9
    vol_lower_ratio: float = 0.04  # relative to min(frame_w, frame_h)
    vol_upper_ratio: float = 0.28  # relative to min(frame_w, frame_h)


SETTINGS = Settings()

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
)
logger = logging.getLogger("gesture-fastapi")

clients = set()
queue = asyncio.Queue()
stop_event = Event()

mp_hands = mp.solutions.hands
mp_draw = mp.solutions.drawing_utils

app = FastAPI()

app.state.last_payload = None
app.state.last_sent_ts = None
app.state.camera_ok = False
app.state.model_ok = True  # legacy field kept for UI compatibility


def _finger_count(hand_landmarks, handedness_label):
    tips = [4, 8, 12, 16, 20]
    pips = [2, 6, 10, 14, 18]

    coords = [(lm.x, lm.y) for lm in hand_landmarks.landmark]

    def _angle(a, b, c):
        # Angle ABC in degrees using 2D points.
        bax = a[0] - b[0]
        bay = a[1] - b[1]
        bcx = c[0] - b[0]
        bcy = c[1] - b[1]
        dot = bax * bcx + bay * bcy
        n1 = (bax * bax + bay * bay) ** 0.5
        n2 = (bcx * bcx + bcy * bcy) ** 0.5
        if n1 == 0.0 or n2 == 0.0:
            return 0.0
        cosv = max(-1.0, min(1.0, dot / (n1 * n2)))
        return float(np.degrees(np.arccos(cosv)))

    # Thumb "extended" is hard to infer from X alone (thumbs-up points mostly vertical).
    # Use a joint angle + relative segment length so it works across rotations/handedness.
    thumb_mcp = coords[2]
    thumb_ip = coords[3]
    thumb_tip = coords[4]
    thumb_ang = _angle(thumb_mcp, thumb_ip, thumb_tip)
    thumb_mcp_tip = ((thumb_tip[0] - thumb_mcp[0]) ** 2 + (thumb_tip[1] - thumb_mcp[1]) ** 2) ** 0.5
    thumb_mcp_ip = ((thumb_ip[0] - thumb_mcp[0]) ** 2 + (thumb_ip[1] - thumb_mcp[1]) ** 2) ** 0.5
    thumb_extended = bool(thumb_ang >= 155.0 and thumb_mcp_ip > 0.0 and thumb_mcp_tip >= (thumb_mcp_ip * 1.15))

    count = 1 if thumb_extended else 0
    fingers_up = []
    # Angle-based finger extension (more robust than y-threshold when the hand is tilted).
    mcp_ids = [5, 9, 13, 17]
    pip_ids = [6, 10, 14, 18]
    tip_ids = [8, 12, 16, 20]
    for i in range(4):
        ang = _angle(coords[mcp_ids[i]], coords[pip_ids[i]], coords[tip_ids[i]])
        tip_y = coords[tip_ids[i]][1]
        pip_y = coords[pip_ids[i]][1]
        # Combine angle + tip-above-pip to avoid falsely counting curled fingers as "up".
        is_up = bool(ang >= 160.0 and (tip_y + 0.015) < pip_y)
        fingers_up.append(is_up)
        if is_up:
            count += 1

    # CV thumbs-up pose (more robust than relying on horizontal thumb extension).
    # Image coords: smaller y is "up" in the frame.
    dx = abs(thumb_tip[0] - thumb_mcp[0])
    dy = thumb_mcp[1] - thumb_tip[1]  # positive when thumb tip is above MCP
    thumb_up_pose = bool(thumb_extended and dy > 0.05 and dy >= (dx * 1.0))
    # Allow a little noise: treat as thumbs-up if at most 1 other finger is detected "up".
    thumbs_up = thumb_up_pose and (sum(1 for up in fingers_up if up) <= 1)
    return count, thumbs_up, fingers_up, thumb_extended


def _broadcast_sync(loop, payload):
    if loop and not loop.is_closed():
        loop.call_soon_threadsafe(queue.put_nowait, payload)

def _probe_camera_read(cap, tries=15, sleep_sec=0.03):
    # Some backends report "opened" but fail to deliver frames (common on Windows).
    for _ in range(int(max(1, tries))):
        ok, frame = cap.read()
        if ok and frame is not None and getattr(frame, "size", 0):
            return True
        time.sleep(float(max(0.0, sleep_sec)))
    return False


def _open_camera():
    # Jetson-friendly: allow either an integer index or a GStreamer pipeline via env var.
    # Examples:
    # - GESTURE_CAMERA=0
    # - GESTURE_CAMERA=0,1
    # - GESTURE_CAMERA="nvarguscamerasrc ! video/x-raw(memory:NVMM), width=1280, height=720, framerate=30/1 ! nvvidconv ! video/x-raw, format=BGRx ! videoconvert ! video/x-raw, format=BGR ! appsink"
    src = (os.getenv("GESTURE_CAMERA") or "").strip()
    candidates = []
    if src:
        if "," in src and all(p.strip().isdigit() for p in src.split(",") if p.strip()):
            candidates = [int(p.strip()) for p in src.split(",") if p.strip()]
        elif src.isdigit():
            candidates = [int(src)]
        else:
            cap = cv2.VideoCapture(src, cv2.CAP_GSTREAMER)
            if cap.isOpened() and _probe_camera_read(cap):
                return cap
            cap.release()
            return None

    if not candidates:
        # Windows often needs CAP_DSHOW; also try a few indices by default.
        candidates = [SETTINGS.camera_index, 0, 1, 2]

    tried = []
    for idx in [c for i, c in enumerate(candidates) if c not in candidates[:i]]:
        tried.append(idx)
        if os.name == "nt":
            cap = cv2.VideoCapture(int(idx), cv2.CAP_DSHOW)
            if cap.isOpened() and _probe_camera_read(cap):
                logger.info("Camera opened (index=%s, backend=DSHOW)", idx)
                return cap
            cap.release()

        cap = cv2.VideoCapture(int(idx))
        if cap.isOpened() and _probe_camera_read(cap):
            logger.info("Camera opened (index=%s)", idx)
            return cap
        cap.release()

    logger.warning("Camera open failed. Tried indices: %s", tried)
    return None


def gesture_worker(loop):
    recent_count = deque(maxlen=SETTINGS.count_stable_n)
    recent_thumbs = deque(maxlen=SETTINGS.count_stable_n)
    last_trigger = 0.0
    last_pinch_trigger = 0.0
    recent_model = deque(maxlen=SETTINGS.model_stable_n)
    last_model_trigger = 0.0
    pinch_state = False
    last_sent = 0.0
    last_log = 0.0
    model = None
    last_frame_ts = None
    fps_smooth = 0.0
    vol_smooth = None

    if SETTINGS.model_enabled and joblib and MODEL_PATH.exists():
        try:
            model = joblib.load(str(MODEL_PATH))
            logger.info("Loaded gesture model: %s", MODEL_PATH)
        except Exception as exc:
            logger.warning("Failed to load gesture model (%s): %s", MODEL_PATH, exc)

    cap = None
    try:
        while not stop_event.is_set():
            if cap is None or not cap.isOpened():
                cap = _open_camera()
                if cap is None:
                    app.state.camera_ok = False
                    logger.warning("Camera open failed. Retrying...")
                    time.sleep(SETTINGS.reconnect_sec)
                    continue
                app.state.camera_ok = True
                logger.info("Camera opened")

            with mp_hands.Hands(
                static_image_mode=False,
                max_num_hands=1,
                min_detection_confidence=0.6,
                min_tracking_confidence=0.6,
            ) as hands:
                while not stop_event.is_set():
                    ok, frame = cap.read()
                    if not ok:
                        logger.warning("Camera read failed. Reopening...")
                        cap.release()
                        cap = None
                        break

                    frame = cv2.flip(frame, 1)
                    rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
                    res = hands.process(rgb)

                gesture = "none"
                conf = 1.0
                stable = False
                finger_count = None  # only emits 1/2/3, else None
                count_stable = False
                thumbs_up = False
                thumbs_up_stable = False
                fingers_up = []
                thumb_extended = False
                pinch = False
                pinch_dist = None
                model_label = None
                model_conf = None
                model_stable = False

                if res.multi_hand_landmarks:
                    hand = res.multi_hand_landmarks[0]
                    mp_draw.draw_landmarks(frame, hand, mp_hands.HAND_CONNECTIONS)
                    handedness = res.multi_handedness[0].classification[0].label if res.multi_handedness else "Right"
                    raw_count, thumbs_up, fingers_up, thumb_extended = _finger_count(hand, handedness)
                    # For the website mapping we only care about 1/2/3. Ignore 0 and >3.
                    finger_count = raw_count if raw_count in (1, 2, 3) else None
                    recent_count.append(finger_count)
                    if (
                        len(recent_count) == SETTINGS.count_stable_n
                        and len(set(recent_count)) == 1
                        and recent_count[0] is not None
                    ):
                        count_stable = True
                    recent_thumbs.append(bool(thumbs_up))
                    thumbs_up_stable = (
                        len(recent_thumbs) == SETTINGS.count_stable_n and all(recent_thumbs)
                    )

                    # Optional ML classifier (trained on hand crops) for more robust "AI" gestures.
                    if model is not None:
                        h, w, _ = frame.shape
                        xs = [lm.x for lm in hand.landmark]
                        ys = [lm.y for lm in hand.landmark]
                        x1 = max(int(min(xs) * w) - 20, 0)
                        y1 = max(int(min(ys) * h) - 20, 0)
                        x2 = min(int(max(xs) * w) + 20, w - 1)
                        y2 = min(int(max(ys) * h) + 20, h - 1)
                        crop = frame[y1:y2, x1:x2]
                        if crop.size != 0:
                            gray = cv2.cvtColor(crop, cv2.COLOR_BGR2GRAY)
                            resized = cv2.resize(gray, (64, 64), interpolation=cv2.INTER_AREA)
                            feat = resized.astype(np.float32).flatten() / 255.0
                            X = np.array(feat, dtype=np.float32).reshape(1, -1)
                            probs = model.predict_proba(X)[0]
                            idx = int(np.argmax(probs))
                            model_conf = float(probs[idx])
                            pred = str(model.classes_[idx])

                            if model_conf >= SETTINGS.model_conf_thresh:
                                recent_model.append(pred)
                            else:
                                recent_model.append("uncertain")

                            if (
                                len(recent_model) == SETTINGS.model_stable_n
                                and len(set(recent_model)) == 1
                                and recent_model[0] != "uncertain"
                            ):
                                model_label = recent_model[0]
                                model_stable = True
                            else:
                                model_label = pred
                                model_stable = False
                        else:
                            recent_model.clear()

                    # CV pinch (thumb tip <-> index tip) to emit squeeze_in / squeeze_out.
                    coords = [(lm.x, lm.y) for lm in hand.landmark]
                    dx = coords[4][0] - coords[8][0]
                    dy = coords[4][1] - coords[8][1]
                    pinch_dist = float((dx * dx + dy * dy) ** 0.5)
                    pinch = pinch_dist < 0.06
                    now = time.time()

                    # FPS (smoothed)
                    if last_frame_ts is not None:
                        dt = max(1e-3, now - last_frame_ts)
                        fps = 1.0 / dt
                        fps_smooth = fps if fps_smooth <= 0.0 else (fps_smooth * 0.9 + fps * 0.1)
                    last_frame_ts = now

                    # Continuous volume from thumb<->index distance (like the tutorial).
                    # Use pixel distance and map to [0..1] based on bounds derived from frame size.
                    h2, w2, _ = frame.shape
                    min_dim = float(min(w2, h2))
                    lower = SETTINGS.vol_lower_ratio * min_dim
                    upper = SETTINGS.vol_upper_ratio * min_dim
                    thumb_px = (int(coords[4][0] * w2), int(coords[4][1] * h2))
                    index_px = (int(coords[8][0] * w2), int(coords[8][1] * h2))
                    line_len_px = float(((thumb_px[0] - index_px[0]) ** 2 + (thumb_px[1] - index_px[1]) ** 2) ** 0.5)
                    if upper <= lower:
                        vol_raw = 0.0
                    else:
                        vol_raw = (line_len_px - lower) / (upper - lower)
                    vol_raw = float(max(0.0, min(1.0, vol_raw)))
                    vol_smooth = vol_raw if vol_smooth is None else (vol_smooth * 0.85 + vol_raw * 0.15)
                    # Hysteresis to reduce flicker
                    if pinch_state:
                        if pinch_dist > 0.08:
                            if now - last_pinch_trigger >= SETTINGS.cooldown_sec:
                                gesture = "squeeze_out"
                                stable = True
                                last_pinch_trigger = now
                            pinch_state = False
                    else:
                        if pinch_dist < 0.05:
                            if now - last_pinch_trigger >= SETTINGS.cooldown_sec:
                                gesture = "squeeze_in"
                                stable = True
                                last_pinch_trigger = now
                            pinch_state = True

                    # ML gesture mapping (thumbs/fist/volume gestures) so frontend can trigger reliably.
                    if model_label:
                        now2 = time.time()
                        if model_stable and (now2 - last_model_trigger) >= SETTINGS.model_cooldown_sec:
                            if model_label == "thumbs":
                                thumbs_up = True
                                thumbs_up_stable = True
                                gesture = "thumbs"
                                stable = True
                            elif model_label == "fist":
                                gesture = "fist"
                                stable = True
                            elif model_label == "rad":
                                gesture = "squeeze_in"
                                stable = True
                            elif model_label == "straight":
                                gesture = "squeeze_out"
                                stable = True
                            elif model_label in ("peace", "okay", "five"):
                                gesture = model_label
                                stable = True
                            last_model_trigger = now2
                        conf = model_conf if model_conf is not None else conf

                payload = {
                    "gesture": gesture,
                    "confidence": round(conf, 3),
                    "stable": stable,
                    "finger_count": finger_count,
                    "count_stable": count_stable,
                    "thumbs_up": thumbs_up,
                    "thumbs_up_stable": thumbs_up_stable if res.multi_hand_landmarks else False,
                    "ai_gesture": model_label,
                    "ai_confidence": round(model_conf, 3) if model_conf is not None else None,
                    "ai_stable": model_stable if model_label is not None else False,
                    "pinch": pinch,
                    "pinch_dist": round(pinch_dist, 3) if pinch_dist is not None else None,
                    "fps": round(fps_smooth, 1) if fps_smooth > 0.0 else None,
                    "volume_level": round(float(vol_smooth), 3) if vol_smooth is not None else None,
                    "timestamp": time.time(),
                }

                now = time.time()
                send_interval = 1.0 / max(1.0, SETTINGS.send_hz)
                should_send = (now - last_sent) >= send_interval

                if should_send:
                    last_sent = now
                    _broadcast_sync(loop, payload)
                    app.state.last_payload = payload
                    app.state.last_sent_ts = now
                    if (now - last_log) >= 1.0:
                        logger.info("WS SEND finger_count=%s thumbs_up=%s gesture=%s", finger_count, thumbs_up, gesture)
                        last_log = now

                    if DEBUG_WINDOW:
                        if fps_smooth > 0.0:
                            cv2.putText(
                                frame,
                                f"FPS: {fps_smooth:.0f}",
                                (20, 25),
                                cv2.FONT_HERSHEY_SIMPLEX,
                                0.7,
                                (255, 0, 255),
                                2,
                            )
                        cv2.putText(frame, f"Gesture: {gesture} conf:{conf:.2f}", (20, 40),
                                    cv2.FONT_HERSHEY_SIMPLEX, 0.9, (0, 255, 0), 2)
                        if vol_smooth is not None:
                            x0, y0, w0, h0 = 20, 60, 14, 140
                            cv2.rectangle(frame, (x0, y0), (x0 + w0, y0 + h0), (0, 255, 0), 2)
                            fill_h = int(h0 * float(vol_smooth))
                            cv2.rectangle(
                                frame,
                                (x0 + 2, y0 + h0 - fill_h),
                                (x0 + w0 - 2, y0 + h0 - 2),
                                (0, 255, 0),
                                -1,
                            )
                            cv2.putText(
                                frame,
                                f"{int(float(vol_smooth) * 100)}",
                                (x0 - 2, y0 + h0 + 25),
                                cv2.FONT_HERSHEY_SIMPLEX,
                                0.7,
                                (0, 255, 0),
                                2,
                            )
                            if res.multi_hand_landmarks:
                                h2, w2, _ = frame.shape
                                coords2 = [(lm.x, lm.y) for lm in res.multi_hand_landmarks[0].landmark]
                                thumb_px = (int(coords2[4][0] * w2), int(coords2[4][1] * h2))
                                index_px = (int(coords2[8][0] * w2), int(coords2[8][1] * h2))
                                cx, cy = (thumb_px[0] + index_px[0]) // 2, (thumb_px[1] + index_px[1]) // 2
                                cv2.circle(frame, thumb_px, 10, (255, 0, 255), cv2.FILLED)
                                cv2.circle(frame, index_px, 10, (255, 0, 255), cv2.FILLED)
                                cv2.circle(frame, (cx, cy), 10, (255, 0, 255), cv2.FILLED)
                                cv2.line(frame, thumb_px, index_px, (255, 0, 255), 3)
                        if fingers_up:
                            cv2.putText(
                                frame,
                                f"Thumb:{'UP' if thumb_extended else 'DOWN'}  Index:{'UP' if fingers_up[0] else 'DOWN'}  Middle:{'UP' if fingers_up[1] else 'DOWN'}",
                                (20, 80),
                                cv2.FONT_HERSHEY_SIMPLEX,
                                0.6,
                                (255, 200, 0),
                                2,
                            )
                            cv2.putText(
                                frame,
                                f"Ring:{'UP' if fingers_up[2] else 'DOWN'}  Pinky:{'UP' if fingers_up[3] else 'DOWN'}",
                                (20, 110),
                                cv2.FONT_HERSHEY_SIMPLEX,
                                0.6,
                                (255, 200, 0),
                                2,
                            )
                            if finger_count is not None:
                                cv2.putText(frame, f"Fingers: {finger_count}", (20, 150),
                                            cv2.FONT_HERSHEY_SIMPLEX, 0.9, (255, 200, 0), 2)
                            if thumbs_up:
                                cv2.putText(frame, "Thumbs Up", (20, 190),
                                            cv2.FONT_HERSHEY_SIMPLEX, 0.8, (255, 200, 0), 2)
                            hint_y = 230 if thumbs_up else 190
                        else:
                            hint_y = 80
                        cv2.putText(frame, "Press Q to quit", (20, hint_y),
                                    cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255, 255, 255), 2)

                        cv2.imshow("Showroom Gesture WS", frame)
                        k = cv2.waitKey(1) & 0xFF
                        if k in (ord("q"), ord("Q")):
                            stop_event.set()
                            break
    except Exception:
        logger.exception("Gesture worker crashed")
    finally:
        if cap is not None:
            cap.release()
        if DEBUG_WINDOW:
            cv2.destroyAllWindows()


async def broadcaster():
    while True:
        payload = await queue.get()
        if not clients:
            continue
        msg = json.dumps(payload)
        await asyncio.gather(
            *[ws.send_text(msg) for ws in list(clients)],
            return_exceptions=True,
        )


@app.get("/health")
async def health():
    return {
        "ok": True,
        "camera_ok": app.state.camera_ok,
        "model_ok": app.state.model_ok,
    }


@app.get("/status")
async def status():
    return {
        "last_payload": app.state.last_payload,
        "last_sent_ts": app.state.last_sent_ts,
        "camera_ok": app.state.camera_ok,
        "model_ok": app.state.model_ok,
        "clients": len(clients),
    }


@app.on_event("startup")
async def on_startup():
    loop = asyncio.get_running_loop()
    app.state.loop = loop
    app.state.broadcaster_task = asyncio.create_task(broadcaster())
    app.state.worker_task = asyncio.create_task(asyncio.to_thread(gesture_worker, loop))


@app.on_event("shutdown")
async def on_shutdown():
    stop_event.set()
    task = getattr(app.state, "broadcaster_task", None)
    if task:
        task.cancel()


@app.websocket("/ws")
async def websocket_endpoint(websocket: WebSocket):
    await websocket.accept()
    clients.add(websocket)
    try:
        initial = app.state.last_payload or {
            "gesture": "none",
            "confidence": 0.0,
            "stable": False,
            "finger_count": None,
            "count_stable": False,
            "thumbs_up": False,
            "thumbs_up_stable": False,
            "ai_gesture": None,
            "ai_confidence": None,
            "ai_stable": False,
            "pinch": False,
            "pinch_dist": None,
            "timestamp": time.time(),
        }
        await websocket.send_text(json.dumps(initial))
    except Exception:
        # If we can't send, treat as disconnected.
        clients.discard(websocket)
        return
    try:
        while True:
            await websocket.receive_text()
    except WebSocketDisconnect:
        clients.discard(websocket)
    except Exception:
        clients.discard(websocket)


if __name__ == "__main__":
    import uvicorn

    uvicorn.run(app, host=HOST, port=PORT)
