# --- TTS (Text-to-Speech) ---
TTS_ENABLED=true
TTS_BACKEND=piper
PIPER_PATH=C:\models\piper\piper.exe
PIPER_MODEL_PATH=C:\models\en_US-kathleen-low.onnx
PIPER_LENGTH_SCALE=0.95
PIPER_NOISE_SCALE=0.6
PIPER_NOISE_W=0.7

# --- Audio Ducking ---
DUCK_ENABLED=true
DUCK_RATIO=0.25

# --- Noise ---
NOISE_REDUCTION=true
NOISE_REDUCTION_PROP=0.6
NOISE_GATE_AUTO=true
NOISE_GATE_MULTIPLIER=3.0
NOISE_GATE_RMS=0.001

# --- Post-TTS mic silence ---
TTS_COOLDOWN_SEC=0.3
WAKE_PROMPT_BLOCK_SEC=0.7

# --- Wake Word Detection ---
WAKE_WORD=jarvis
WAKE_PHRASE=hey jarvis
OWW_MODEL_PATH=hey_jarvis_v0.1.tflite
OWW_THRESHOLD=0.20

# --- ASR ---
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_API_KEY
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en-US
DEEPGRAM_ENDPOINTING_MS=300
VOSK_MODEL_PATH=C:\path\to\vosk-model-small-en-us-0.15

# --- Audio Source ---
AUDIO_SOURCE=browser
AUDIO_DEVICE=

# --- Listening Behaviour ---
ALWAYS_LISTEN=false
LISTEN_WINDOW_SEC=10.0
MAX_UTTERANCE_SEC=5.0
VAD_SILENCE_SEC=0.8

# --- Intent Classification ---
INTENT_THRESHOLD=0.6
INTENT_CONFIG_DEEPGRAM_PATH=C:\path\to\gesture-showroom\voice\config\intent_deepgram.json
INTENT_CONFIG_VOSK_PATH=C:\path\to\gesture-showroom\voice\config\intent_vosk.json
ASR_MIN_CONF=0.45
USE_EMBEDDINGS=false
TRANSCRIPT_DEBUG_ENABLED=true
TRANSCRIPT_DEBUG_MAX=25

# --- Wake Response ---
WAKE_RESPONSE=How may I help you?

# --- Gain ---
MAX_GAIN=8
TARGET_RMS=0.08
