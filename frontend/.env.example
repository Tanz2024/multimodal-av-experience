## Frontend dev proxy targets (optional)
## If your backends are not on the default ports, set these in `.env` (not committed).
##
## Examples:
## VOICE_PROXY_TARGET=http://127.0.0.1:8010
## VITE_VOICE_UI_SYNC_URL=http://127.0.0.1:8010/ui_sync
##
## If you are running Vite in WSL but the Python backend on Windows,
## point these to your Windows host IP (e.g. http://192.168.1.10:8010).
#
# VOICE_PROXY_TARGET=http://127.0.0.1:8010
# VITE_VOICE_UI_SYNC_URL=http://127.0.0.1:8010/ui_sync

## HTTPS dev server (recommended for mobile testing)
## Default is true; set to false if you explicitly need plain HTTP.
# VITE_HTTPS=true

## Set to true when backend TTS is enabled to avoid browser double-speaking.
# VITE_BACKEND_TTS=true

## Enable browser speech synthesis fallback when backend TTS is disabled.
## Default is false to keep TTS fully off when backend TTS is off.
# VITE_BROWSER_TTS=false

## Optional: force browser TTS regardless of backend TTS state.
# VITE_FORCE_BROWSER_TTS=false
